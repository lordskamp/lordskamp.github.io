# Зберігайте ці значення лише як зашифровані Cloudflare Worker secrets.
SHYFR_BOT_TOKEN=
SHYFR_WEBHOOK_SECRET=
SHYFR_ADMIN_TOKEN=

# Звичайні Worker variables.
SHYFR_MINI_APP_URL=https://lordskamp.github.io/shyfr/
SHYFR_PAYMENT_SUPPORT=@replace_with_support_username
SHYFR_INITIAL_LIVES=5
SHYFR_MAX_LIVES=8
SHYFR_INITIAL_HINTS=3
SHYFR_MAX_HINTS=25
SHYFR_CATEGORY_PRICE_STARS=200
SHYFR_LEVEL_PRICE_STARS=10
SHYFR_LIVES_PACK_QUANTITY=3
SHYFR_LIVES_PACK_STARS=30
SHYFR_HINTS_PACK_QUANTITY=5
SHYFR_HINTS_PACK_STARS=20

# Лише для локального імпорту платного контенту; обидва шляхи — поза репозиторієм.
SHYFR_PRIVATE_CONTENT_ROOT=
SHYFR_PRIVATE_KV_OUTPUT=

# Наявні значення «Кобза-навпаки» залишаються окремими.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=unwordle_bot
